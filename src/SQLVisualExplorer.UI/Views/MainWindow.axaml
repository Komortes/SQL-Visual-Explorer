<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SQLVisualExplorer.UI.Controls"
        x:Class="SQLVisualExplorer.UI.Views.MainWindow"
        Title="SQL Visual Explorer"
        Width="1200"
        Height="800"
        MinWidth="980"
        MinHeight="640"
        Background="#101418">
  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#E7ECEF" />
      <Setter Property="FontFamily" Value="Inter" />
    </Style>

    <Style Selector="Button.nav-item">
      <Setter Property="Height" Value="58" />
      <Setter Property="Margin" Value="10,4" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1B242C" />
    </Style>

    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#141A20" />
      <Setter Property="BorderBrush" Value="#26313A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="34" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="MinHeight" Value="34" />
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="56,*" ColumnDefinitions="92,*">
    <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            Background="#0D1115"
            BorderBrush="#222B33"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="18,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
          <Border Width="28" Height="28" CornerRadius="7" Background="#2F80ED" ClipToBounds="True">
            <Viewbox Margin="5">
              <Canvas Width="20" Height="20">
                <Ellipse Canvas.Left="1" Canvas.Top="0" Width="18" Height="6"
                         Stroke="White" StrokeThickness="1.3" Fill="White" Opacity="0.6"/>
                <Rectangle Canvas.Left="1" Canvas.Top="3" Width="18" Height="9"
                           Fill="White" Opacity="0.4"/>
                <Ellipse Canvas.Left="1" Canvas.Top="8" Width="18" Height="6"
                         Stroke="White" StrokeThickness="1.3" Fill="White" Opacity="0.75"/>
                <Ellipse Canvas.Left="10" Canvas.Top="8" Width="8" Height="8"
                         Stroke="White" StrokeThickness="1.5" Fill="#2F80ED" Opacity="0.95"/>
                <Path Data="M17,15 L20,18"
                      Stroke="White" StrokeThickness="2" StrokeLineCap="Round" Opacity="0.95"/>
              </Canvas>
            </Viewbox>
          </Border>
          <TextBlock Text="SQL Visual Explorer"
                     FontSize="13"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
        </StackPanel>

        <Border Grid.Column="1"
                Width="280"
                Height="34"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                Background="#151C22"
                BorderBrush="#2A3640"
                BorderThickness="1"
                CornerRadius="6">
          <ComboBox ItemsSource="{Binding Connections}"
                    SelectedItem="{Binding SelectedConnection}"
                    Background="Transparent"
                    BorderBrush="Transparent"
                    HorizontalAlignment="Stretch"
                    VerticalAlignment="Center"
                    PlaceholderText="No connection selected">
            <ComboBox.ItemTemplate>
              <DataTemplate>
                <TextBlock Text="{Binding Name}" />
              </DataTemplate>
            </ComboBox.ItemTemplate>
          </ComboBox>
        </Border>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
          <Button Width="34" Height="34" Padding="0" Background="#151C22" BorderBrush="#2A3640" CornerRadius="6">
            <TextBlock Text="!" HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
          <Button Width="34" Height="34" Padding="0" Background="#151C22" BorderBrush="#2A3640" CornerRadius="6">
            <TextBlock Text="..." HorizontalAlignment="Center" VerticalAlignment="Center" />
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="0"
            Background="#0D1115"
            BorderBrush="#222B33"
            BorderThickness="0,0,1,0">
      <ItemsControl ItemsSource="{Binding NavigationItems}" Margin="0,14">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button Classes="nav-item"
                    Command="{Binding DataContext.SelectNavigationItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    Background="{Binding NavBackground}"
                    Opacity="{Binding NavOpacity}">
              <StackPanel Spacing="4">
                <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                  <Path Data="{Binding IconPath}"
                        Stroke="#80B8FF"
                        StrokeThickness="1.3"
                        Fill="Transparent"
                        StrokeLineCap="Round"
                        Width="16" Height="16"
                        Stretch="Uniform"/>
                </Viewbox>
                <TextBlock Text="{Binding Label}"
                           FontSize="10"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>

    <Grid Grid.Row="1"
          Grid.Column="1"
          RowDefinitions="Auto,*,210"
          Margin="20"
          RowSpacing="16">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="{Binding ActiveTitle}" FontSize="24" FontWeight="SemiBold" />
          <TextBlock Text="{Binding ActiveSubtitle}"
                     FontSize="13"
                     Foreground="#91A0AD" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="8"
                    IsVisible="{Binding IsWorkspaceVisible}">
          <Button Content="Run"
                  Height="34"
                  Padding="16,0"
                  CornerRadius="6"
                  Command="{Binding RunQueryCommand}" />
          <Button Content="Explain"
                  Height="34"
                  Padding="16,0"
                  CornerRadius="6"
                  Command="{Binding ExplainQueryCommand}" />
          <Button Content="Analyze"
                  Height="34"
                  Padding="16,0"
                  CornerRadius="6"
                  Command="{Binding ExplainAnalyzeQueryCommand}" />
        </StackPanel>
      </Grid>

      <Grid Grid.Row="1"
            ColumnDefinitions="2*,*"
            ColumnSpacing="16"
            IsVisible="{Binding IsWorkspaceVisible}">
        <Border Classes="panel"
                IsVisible="{Binding IsEditorVisible}">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Text="SQL Editor" FontSize="14" FontWeight="SemiBold" />
            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Background="#0F1419"
                    BorderBrush="#26313A"
                    BorderThickness="1"
                    CornerRadius="6"
                    Padding="14">
              <TextBox Text="{Binding SqlText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       AcceptsReturn="True"
                       TextWrapping="Wrap"
                       FontFamily="Menlo, Consolas, monospace"
                       FontSize="13"
                       Background="Transparent"
                       BorderBrush="Transparent"
                       Foreground="#CFE3F2"
                       Watermark="select * from table_name limit 100;" />
            </Border>
          </Grid>
        </Border>

        <Border Classes="panel"
                IsVisible="{Binding IsPlanVisible}">
          <Grid RowDefinitions="Auto,*">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="{Binding PlanTreeHeaderText}" FontSize="14" FontWeight="SemiBold" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border BorderBrush="#2A3640" BorderThickness="1" CornerRadius="5" ClipToBounds="True">
                  <StackPanel Orientation="Horizontal">
                    <Button Content="Graph"
                            Height="26"
                            Padding="10,0"
                            CornerRadius="0"
                            Command="{Binding ShowPlanTreeCommand}" />
                    <Button Content="Flame"
                            Height="26"
                            Padding="10,0"
                            CornerRadius="0"
                            Command="{Binding ShowPlanFlamegraphCommand}" />
                  </StackPanel>
                </Border>
                <Button Content="−" Width="26" Height="26" Padding="0" CornerRadius="5"
                        Command="{Binding ZoomOutCommand}" />
                <Button Content="+" Width="26" Height="26" Padding="0" CornerRadius="5"
                        Command="{Binding ZoomInCommand}" />
                <Button Content="fit" Width="36" Height="26" Padding="0" CornerRadius="5"
                        Command="{Binding ZoomFitCommand}" />
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="8,0,0,0">
                  <Border Width="8" Height="8" CornerRadius="4" Background="#7BD88F" VerticalAlignment="Center" />
                  <TextBlock Text="OK" FontSize="10" Foreground="#91A0AD" VerticalAlignment="Center"/>
                  <Border Width="8" Height="8" CornerRadius="4" Background="#FFD166" VerticalAlignment="Center" Margin="6,0,0,0"/>
                  <TextBlock Text="Warn" FontSize="10" Foreground="#91A0AD" VerticalAlignment="Center"/>
                  <Border Width="8" Height="8" CornerRadius="4" Background="#FF8A7A" VerticalAlignment="Center" Margin="6,0,0,0"/>
                  <TextBlock Text="Crit" FontSize="10" Foreground="#91A0AD" VerticalAlignment="Center"/>
                </StackPanel>
              </StackPanel>
            </Grid>

            <controls:PlanGraphControl
                Grid.Row="1"
                Margin="0,12,0,0"
                IsVisible="{Binding IsPlanTreeVisible}"
                NodesSource="{Binding VisualPlanNodes}"
                EdgesSource="{Binding GraphEdges}"
                CanvasWidth="{Binding GraphWidth}"
                CanvasHeight="{Binding GraphHeight}"
                GraphZoom="{Binding GraphZoom}"
                DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>

            <ScrollViewer Grid.Row="1"
                          Margin="0,12,0,0"
                          IsVisible="{Binding IsPlanFlamegraphVisible}">
              <ItemsControl ItemsSource="{Binding VisualPlanNodes}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Margin="{Binding FlameMargin}"
                            Padding="0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            HorizontalAlignment="Left"
                            Command="{Binding DataContext.SelectPlanNodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}">
                      <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Width="{Binding FlameBarWidth}"
                                Height="34"
                                Background="{Binding AccentColor}"
                                BorderBrush="{Binding SelectionBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="12"
                                    VerticalAlignment="Center">
                          <TextBlock Text="{Binding Label}"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     TextWrapping="NoWrap" />
                          <TextBlock Text="{Binding FlameMetricText}"
                                     FontSize="12"
                                     Foreground="#91A0AD" />
                          <TextBlock Text="{Binding IssueText}"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Foreground="{Binding IssueColor}" />
                        </StackPanel>
                      </Grid>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>

        <Border Grid.Column="1" Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Text="Plan Summary" FontSize="14" FontWeight="SemiBold" />
            <Border Padding="10"
                    Background="#0F1419"
                    BorderBrush="#26313A"
                    BorderThickness="1"
                    CornerRadius="6">
              <TextBlock Text="{Binding PlanSummaryText}"
                         FontFamily="Menlo, Consolas, monospace"
                         FontSize="11"
                         Foreground="#91A0AD"
                         TextWrapping="Wrap"
                         LineHeight="18" />
            </Border>
            <Border Height="1" Background="#26313A" />
            <TextBlock Text="Selected Node" FontSize="14" FontWeight="SemiBold" />
            <Border Padding="10"
                    Background="#0F1419"
                    BorderBrush="#26313A"
                    BorderThickness="1"
                    CornerRadius="8">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding SelectedPlanNodeTitle}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding SelectedPlanNodeDetails}"
                           FontFamily="Menlo, Consolas, monospace"
                           FontSize="12"
                           Foreground="#91A0AD"
                           TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding SelectedPlanNodeIssues}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,6"
                              Padding="8"
                              Background="#17212A"
                              BorderBrush="#2A3640"
                              BorderThickness="1"
                              CornerRadius="6">
                        <StackPanel Spacing="4">
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding Code}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#C6D0D8" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Severity}"
                                       FontSize="11"
                                       Foreground="{Binding SeverityColor}" />
                          </Grid>
                          <TextBlock Text="{Binding Recommendation}"
                                     FontSize="11"
                                     Foreground="#91A0AD"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
            <Border Height="1" Background="#26313A" />
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Text="Issues" FontSize="14" FontWeight="SemiBold" />
              <Border Padding="6,2"
                      Background="#1F1010"
                      BorderBrush="#3A2020"
                      BorderThickness="1"
                      CornerRadius="4"
                      IsVisible="{Binding HasPlanIssues}">
                <TextBlock Text="{Binding PlanIssuesBadgeText}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{Binding PlanIssuesBadgeColor}" />
              </Border>
            </StackPanel>
            <ScrollViewer MaxHeight="220">
              <ItemsControl ItemsSource="{Binding PlanIssues}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="10"
                            Background="#0F1419"
                            BorderBrush="#26313A"
                            BorderThickness="1"
                            CornerRadius="8">
                      <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Text="{Binding Title}"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Severity}"
                                     Foreground="{Binding SeverityColor}"
                                     FontSize="12"
                                     FontWeight="SemiBold" />
                        </Grid>
                        <TextBlock Text="{Binding Code}"
                                   FontSize="11"
                                   Foreground="#6F7E89" />
                        <TextBlock Text="{Binding Description}"
                                   FontSize="12"
                                   Foreground="#C6D0D8"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Recommendation}"
                                   FontSize="12"
                                   Foreground="#91A0AD"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
            <Border Height="1" Background="#26313A" />
            <TextBlock Text="Session Password" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Text="Used only for Run in this session. It is not saved."
                       TextWrapping="Wrap"
                       FontSize="12"
                       Foreground="#91A0AD" />
            <TextBox Text="{Binding SelectedConnectionPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     PasswordChar="*"
                     Watermark="Password for selected connection" />
          </StackPanel>
        </Border>
      </Grid>

      <Grid Grid.Row="1"
            Grid.RowSpan="2"
            ColumnDefinitions="360,*"
            ColumnSpacing="16"
            IsVisible="{Binding IsConnectionsVisible}">
        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Text="New Connection" FontSize="14" FontWeight="SemiBold" />

            <StackPanel Spacing="6">
              <TextBlock Text="Name" FontSize="12" Foreground="#91A0AD" />
              <TextBox Text="{Binding NewConnectionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Watermark="Production DB" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="Type" FontSize="12" Foreground="#91A0AD" />
              <ComboBox ItemsSource="{Binding DatabaseTypeOptions}"
                        SelectedItem="{Binding NewConnectionDatabaseType}" />
            </StackPanel>

            <Grid ColumnDefinitions="*,100" ColumnSpacing="10">
              <StackPanel Spacing="6">
                <TextBlock Text="Host" FontSize="12" Foreground="#91A0AD" />
                <TextBox Text="{Binding NewConnectionHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Watermark="localhost" />
              </StackPanel>

              <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock Text="Port" FontSize="12" Foreground="#91A0AD" />
                <TextBox Text="{Binding NewConnectionPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Watermark="5432" />
              </StackPanel>
            </Grid>

            <StackPanel Spacing="6">
              <TextBlock Text="Database" FontSize="12" Foreground="#91A0AD" />
              <TextBox Text="{Binding NewConnectionDatabase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Watermark="app_db" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="Username" FontSize="12" Foreground="#91A0AD" />
              <TextBox Text="{Binding NewConnectionUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Watermark="postgres" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="Password" FontSize="12" Foreground="#91A0AD" />
              <TextBox Text="{Binding NewConnectionPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PasswordChar="*"
                       Watermark="Used for test only" />
            </StackPanel>

            <CheckBox Content="Use SSL" IsChecked="{Binding NewConnectionUseSsl}" />

            <Grid ColumnDefinitions="*,*" ColumnSpacing="10">
              <Button Content="Test Connection"
                      Height="36"
                      HorizontalAlignment="Stretch"
                      Command="{Binding TestConnectionCommand}" />
              <Button Grid.Column="1"
                      Content="Save Connection"
                      Height="36"
                      HorizontalAlignment="Stretch"
                      Command="{Binding SaveConnectionCommand}" />
            </Grid>

            <TextBlock Text="{Binding ConnectionStatusMessage}"
                       FontSize="12"
                       Foreground="#91A0AD"
                       TextWrapping="Wrap" />
            <TextBlock Text="Passwords are not stored yet; Keychain support will be added separately."
                       FontSize="11"
                       Foreground="#6F7E89"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Classes="panel">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Text="Saved Connections" FontSize="14" FontWeight="SemiBold" />

            <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
              <ItemsControl ItemsSource="{Binding Connections}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="14"
                            Background="#0F1419"
                            BorderBrush="#26313A"
                            BorderThickness="1"
                            CornerRadius="8">
                      <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="Auto,*">
                          <Border Padding="6,3"
                                  Background="#17212A"
                                  BorderBrush="#2A3640"
                                  BorderThickness="1"
                                  CornerRadius="5">
                            <TextBlock Text="{Binding DatabaseTypeShort}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{Binding DatabaseTypeColor}" />
                          </Border>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Name}"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     Margin="10,0,0,0"
                                     VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock Text="{Binding Endpoint}"
                                   FontSize="12"
                                   Foreground="#91A0AD" />

                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8">
                          <TextBlock Text="{Binding Database}"
                                     FontSize="12"
                                     Foreground="#C6D0D8"
                                     VerticalAlignment="Center" />
                          <Button Grid.Column="1"
                                  Content="Connect"
                                  Height="28"
                                  Padding="10,0"
                                  CornerRadius="5"
                                  Command="{Binding DataContext.SelectConnectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                          <Button Grid.Column="2"
                                  Content="Edit"
                                  Height="28"
                                  Padding="10,0"
                                  CornerRadius="5"
                                  Background="#17212A"
                                  BorderBrush="#2A3640" />
                          <Button Grid.Column="3"
                                  Content="Delete"
                                  Height="28"
                                  Padding="10,0"
                                  CornerRadius="5"
                                  Background="Transparent"
                                  BorderBrush="#3A2020"
                                  Foreground="#FF8A7A"
                                  Command="{Binding DataContext.DeleteConnectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                        </Grid>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Row="1"
              Grid.RowSpan="2"
              Classes="panel"
              IsVisible="{Binding IsHistoryVisible}">
        <Grid RowDefinitions="Auto,*">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Recent Queries" FontSize="14" FontWeight="SemiBold" />
            <Button Grid.Column="1"
                    Content="Refresh"
                    Height="32"
                    Padding="14,0"
                    Command="{Binding LoadHistoryCommand}" />
          </Grid>

          <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
            <ItemsControl ItemsSource="{Binding HistoryItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,8"
                          Padding="12,10"
                          Background="#0F1419"
                          BorderBrush="#26313A"
                          BorderThickness="1"
                          CornerRadius="7">
                    <StackPanel Spacing="6">
                      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
                        <Border Padding="5,2"
                                Background="{Binding StatusBadgeBackground}"
                                CornerRadius="3"
                                VerticalAlignment="Center">
                          <TextBlock Text="{Binding StatusBadgeText}"
                                     FontSize="9"
                                     FontWeight="Bold"
                                     Foreground="{Binding StatusBadgeForeground}" />
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ConnectionName}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#C6D0D8"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ExecutedAt}"
                                   FontSize="10"
                                   Foreground="#4A5A66"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3"
                                   Text="{Binding Duration}"
                                   FontSize="10"
                                   Foreground="#91A0AD"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="4"
                                   Text="{Binding RowCount}"
                                   FontSize="10"
                                   Foreground="#91A0AD"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="5"
                                Content="Open"
                                Height="26"
                                Padding="8,0"
                                CornerRadius="4"
                                Command="{Binding DataContext.OpenHistoryItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                      </Grid>

                      <Border Padding="8,6"
                              Background="#0A0F13"
                              BorderBrush="#1E2830"
                              BorderThickness="1"
                              CornerRadius="5">
                        <TextBlock Text="{Binding SqlPreview}"
                                   FontFamily="Menlo, Consolas, monospace"
                                   FontSize="11"
                                   Foreground="#CFE3F2"
                                   TextWrapping="NoWrap" />
                      </Border>

                      <TextBlock Text="{Binding ErrorMessage}"
                                 FontSize="11"
                                 Foreground="#FF8A7A"
                                 TextWrapping="Wrap"
                                 IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <Border Grid.Row="2" Classes="panel" IsVisible="{Binding IsWorkspaceVisible}">
        <Grid RowDefinitions="Auto,*">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Results" FontSize="14" FontWeight="SemiBold" />
            <TextBlock Grid.Column="1"
                       Text="{Binding QueryStatusMessage}"
                       FontSize="12"
                       Foreground="#91A0AD"
                       VerticalAlignment="Center" />
          </Grid>
          <Grid Grid.Row="1"
                Margin="0,12,0,0"
                RowDefinitions="36,*">
            <Border Background="#0F1419" BorderBrush="#26313A" BorderThickness="0,0,0,1">
              <TextBlock Text="{Binding ResultHeaderText}"
                         VerticalAlignment="Center"
                         Margin="12,0"
                         FontFamily="Menlo, Consolas, monospace"
                         FontSize="12"
                         Foreground="#91A0AD" />
            </Border>

            <ScrollViewer Grid.Row="1">
              <ItemsControl ItemsSource="{Binding ResultRows}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Padding="12,8"
                            BorderBrush="#202B33"
                            BorderThickness="0,0,0,1">
                      <TextBlock Text="{Binding DisplayText}"
                                 FontFamily="Menlo, Consolas, monospace"
                                 FontSize="12"
                                 Foreground="#CFE3F2" />
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Grid>
      </Border>
    </Grid>
  </Grid>
</Window>
