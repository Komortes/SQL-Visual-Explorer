<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:SQLVisualExplorer.UI.Controls"
        x:Class="SQLVisualExplorer.UI.Views.MainWindow"
        Title="SQL Visual Explorer"
        Width="1200"
        Height="800"
        MinWidth="980"
        MinHeight="640"
        Background="#101418">
  <Window.KeyBindings>
    <KeyBinding Gesture="Ctrl+Return" Command="{Binding RunQueryCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+Return" Command="{Binding ExplainAnalyzeQueryCommand}" />
    <KeyBinding Gesture="Ctrl+OemQuestion" Command="{Binding OpenSnippetsPopupCommand}" />
    <KeyBinding Gesture="Ctrl+Shift+F" Command="{Binding FormatSqlCommand}" />
  </Window.KeyBindings>
  <Window.Styles>
    <Style Selector="TextBlock">
      <Setter Property="Foreground" Value="#E7ECEF" />
      <Setter Property="FontFamily" Value="Inter" />
    </Style>

    <Style Selector="Button.nav-item">
      <Setter Property="Height" Value="58" />
      <Setter Property="Margin" Value="10,4" />
      <Setter Property="Padding" Value="8" />
      <Setter Property="Background" Value="Transparent" />
      <Setter Property="BorderBrush" Value="Transparent" />
      <Setter Property="CornerRadius" Value="6" />
      <Setter Property="HorizontalContentAlignment" Value="Stretch" />
      <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

    <Style Selector="Button.nav-item:pointerover /template/ ContentPresenter">
      <Setter Property="Background" Value="#1B242C" />
    </Style>

    <Style Selector="Border.panel">
      <Setter Property="Background" Value="#141A20" />
      <Setter Property="BorderBrush" Value="#26313A" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="16" />
    </Style>

    <Style Selector="TextBox">
      <Setter Property="MinHeight" Value="34" />
    </Style>

    <Style Selector="ComboBox">
      <Setter Property="MinHeight" Value="34" />
    </Style>

    <!-- Nav panel entrance: fades in when IsVisible becomes true -->
    <Style Selector="Grid.content-view[IsVisible=true]">
      <Style.Animations>
        <Animation Duration="0:0:0.20" FillMode="Forward" Easing="CubicEaseOut">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <Style Selector="Border.content-view[IsVisible=true]">
      <Style.Animations>
        <Animation Duration="0:0:0.20" FillMode="Forward" Easing="CubicEaseOut">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>

    <!-- Nav button: smooth hover background via ContentPresenter transition -->
    <Style Selector="Button.nav-item /template/ ContentPresenter">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>

    <!-- Nav button: smooth opacity transition between active and inactive states -->
    <Style Selector="Button.nav-item">
      <Setter Property="Transitions">
        <Transitions>
          <DoubleTransition Property="Opacity" Duration="0:0:0.15" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>

    <!-- Ghost buttons in topbar: smooth border-area hover -->
    <Style Selector="Button.topbar-action /template/ ContentPresenter">
      <Setter Property="Transitions">
        <Transitions>
          <BrushTransition Property="Background" Duration="0:0:0.12" Easing="CubicEaseOut" />
        </Transitions>
      </Setter>
    </Style>

    <!-- List item entrance: fades in as items are added to collections -->
    <Style Selector="Border.list-item">
      <Style.Animations>
        <Animation Duration="0:0:0.18" FillMode="Forward" Easing="CubicEaseOut">
          <KeyFrame Cue="0%">
            <Setter Property="Opacity" Value="0" />
          </KeyFrame>
          <KeyFrame Cue="100%">
            <Setter Property="Opacity" Value="1" />
          </KeyFrame>
        </Animation>
      </Style.Animations>
    </Style>
  </Window.Styles>

  <Grid RowDefinitions="56,*" ColumnDefinitions="92,*">
    <Border Grid.Row="0"
            Grid.ColumnSpan="2"
            Background="#0D1115"
            BorderBrush="#222B33"
            BorderThickness="0,0,0,1">
      <Grid ColumnDefinitions="Auto,*,Auto" Margin="18,0">
        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Spacing="10">
          <Border Width="28" Height="28" CornerRadius="7" Background="#2F80ED" ClipToBounds="True">
            <Viewbox Margin="5">
              <Canvas Width="20" Height="20">
                <Ellipse Canvas.Left="1" Canvas.Top="0" Width="18" Height="6"
                         Stroke="White" StrokeThickness="1.3" Fill="White" Opacity="0.6"/>
                <Rectangle Canvas.Left="1" Canvas.Top="3" Width="18" Height="9"
                           Fill="White" Opacity="0.4"/>
                <Ellipse Canvas.Left="1" Canvas.Top="8" Width="18" Height="6"
                         Stroke="White" StrokeThickness="1.3" Fill="White" Opacity="0.75"/>
                <Ellipse Canvas.Left="10" Canvas.Top="8" Width="8" Height="8"
                         Stroke="White" StrokeThickness="1.5" Fill="#2F80ED" Opacity="0.95"/>
                <Path Data="M17,15 L20,18"
                      Stroke="White" StrokeThickness="2" StrokeLineCap="Round" Opacity="0.95"/>
              </Canvas>
            </Viewbox>
          </Border>
          <TextBlock Text="SQL Visual Explorer"
                     FontSize="13"
                     FontWeight="SemiBold"
                     VerticalAlignment="Center" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="6">
          <Border Width="240"
                  Height="34"
                  Background="#151C22"
                  BorderBrush="#2A3640"
                  BorderThickness="1"
                  CornerRadius="6">
            <ComboBox ItemsSource="{Binding Connections}"
                      SelectedItem="{Binding SelectedConnection}"
                      Background="Transparent"
                      BorderBrush="Transparent"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Center"
                      PlaceholderText="No connection selected">
              <ComboBox.ItemTemplate>
                <DataTemplate>
                  <TextBlock Text="{Binding Name}" />
                </DataTemplate>
              </ComboBox.ItemTemplate>
            </ComboBox>
          </Border>
          <Border Height="34"
                  Background="#151C22"
                  BorderBrush="#2A3640"
                  BorderThickness="1"
                  CornerRadius="6"
                  IsVisible="{Binding SelectedConnection, Converter={x:Static ObjectConverters.IsNotNull}}">
            <Grid ColumnDefinitions="Auto,160" VerticalAlignment="Center" Margin="8,0">
              <Viewbox Width="11" Height="11" Margin="0,0,5,0">
                <Path Data="M3,8 H13 V14 H3 Z M5,8 V5.5 A3,3,0,0,1,11,5.5 V8"
                      Stroke="#6F7E89"
                      StrokeThickness="1.4"
                      StrokeLineCap="Round"
                      Fill="Transparent" />
              </Viewbox>
              <TextBox Grid.Column="1"
                       Text="{Binding SelectedConnectionPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PasswordChar="*"
                       Watermark="password"
                       FontSize="12"
                       Background="Transparent"
                       BorderBrush="Transparent"
                       Foreground="#C6D0D8"
                       MinHeight="0" />
            </Grid>
          </Border>
        </StackPanel>

        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
          <Button Width="34" Height="34" Padding="0"
                  Background="#151C22" BorderBrush="#2A3640" CornerRadius="6"
                  ToolTip.Tip="More actions">
            <TextBlock Text="⋯" FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center" />
            <Button.Flyout>
              <MenuFlyout>
                <MenuItem Header="Save query as snippet"
                          Command="{Binding SaveCurrentQueryAsSnippetCommand}" />
                <MenuItem Header="Export results to CSV"
                          Command="{Binding ExportResultsToCsvCommand}" />
                <MenuItem Header="Export results to JSON"
                          Command="{Binding ExportResultsToJsonCommand}" />
                <Separator />
                <MenuItem Header="About SQL Visual Explorer"
                          Command="{Binding ShowAboutCommand}" />
              </MenuFlyout>
            </Button.Flyout>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <Border Grid.Row="1"
            Grid.Column="0"
            Background="#0D1115"
            BorderBrush="#222B33"
            BorderThickness="0,0,1,0">
      <ItemsControl ItemsSource="{Binding NavigationItems}" Margin="0,14">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <Button Classes="nav-item"
                    Command="{Binding DataContext.SelectNavigationItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                    CommandParameter="{Binding}"
                    Background="{Binding NavBackground}"
                    Opacity="{Binding NavOpacity}">
              <StackPanel Spacing="4">
                <Viewbox Width="18" Height="18" HorizontalAlignment="Center">
                  <Path Data="{Binding IconPath}"
                        Stroke="#80B8FF"
                        StrokeThickness="1.3"
                        Fill="Transparent"
                        StrokeLineCap="Round"
                        Width="16" Height="16"
                        Stretch="Uniform"/>
                </Viewbox>
                <TextBlock Text="{Binding Label}"
                           FontSize="10"
                           HorizontalAlignment="Center" />
              </StackPanel>
            </Button>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>
    </Border>

    <Grid Grid.Row="1"
          Grid.Column="1"
          RowDefinitions="Auto,*,210"
          Margin="20"
          RowSpacing="16">
      <Grid ColumnDefinitions="*,Auto">
        <StackPanel Spacing="4">
          <TextBlock Text="{Binding ActiveTitle}" FontSize="24" FontWeight="SemiBold" />
          <TextBlock Text="{Binding ActiveSubtitle}"
                     FontSize="13"
                     Foreground="#91A0AD" />
        </StackPanel>

        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    VerticalAlignment="Center"
                    Spacing="8"
                    IsVisible="{Binding IsWorkspaceVisible}">
          <TextBlock Text="Running…"
                     FontSize="12"
                     Foreground="#91A0AD"
                     VerticalAlignment="Center"
                     IsVisible="{Binding IsBusy}" />
          <Button Content="Cancel"
                  Height="34"
                  Padding="14,0"
                  CornerRadius="6"
                  Background="Transparent"
                  BorderBrush="#3A2020"
                  Foreground="#FF8A7A"
                  IsVisible="{Binding IsBusy}"
                  Command="{Binding CancelRunCommand}" />
          <Button Content="Run"
                  Height="34"
                  Padding="16,0"
                  CornerRadius="6"
                  Command="{Binding RunQueryCommand}" />
          <Button Content="Explain"
                  Height="34"
                  Padding="16,0"
                  CornerRadius="6"
                  Command="{Binding ExplainQueryCommand}" />
          <Button Content="Analyze"
                  Height="34"
                  Padding="16,0"
                  CornerRadius="6"
                  Command="{Binding ExplainAnalyzeQueryCommand}" />
          <Button Content="Format"
                  Height="34"
                  Padding="16,0"
                  CornerRadius="6"
                  ToolTip.Tip="Format SQL (Ctrl+Shift+F)"
                  Command="{Binding FormatSqlCommand}" />
        </StackPanel>
      </Grid>

      <Grid Grid.Row="1"
            Classes="content-view"
            ColumnDefinitions="2*,*"
            ColumnSpacing="16"
            IsVisible="{Binding IsWorkspaceVisible}">
        <Border Classes="panel"
                IsVisible="{Binding IsEditorVisible}">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Text="SQL Editor" FontSize="14" FontWeight="SemiBold" />
            <Border Grid.Row="1"
                    Margin="0,12,0,0"
                    Background="#0A0F13"
                    BorderBrush="#26313A"
                    BorderThickness="1"
                    CornerRadius="6"
                    ClipToBounds="True">
              <controls:SqlEditorControl SqlText="{Binding SqlText, Mode=TwoWay}" />
            </Border>
          </Grid>
        </Border>

        <Border Classes="panel"
                IsVisible="{Binding IsPlanVisible}">
          <Grid RowDefinitions="Auto,*,Auto">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="{Binding PlanTreeHeaderText}" FontSize="14" FontWeight="SemiBold" />
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <Border BorderBrush="#2A3640" BorderThickness="1" CornerRadius="5" ClipToBounds="True">
                  <StackPanel Orientation="Horizontal">
                    <Button Content="Tree"
                            Height="26"
                            Padding="10,0"
                            CornerRadius="0"
                            Command="{Binding ShowPlanTableCommand}" />
                    <Button Content="Graph"
                            Height="26"
                            Padding="10,0"
                            CornerRadius="0"
                            Command="{Binding ShowPlanGraphCommand}" />
                    <Button Content="Flame"
                            Height="26"
                            Padding="10,0"
                            CornerRadius="0"
                            Command="{Binding ShowPlanFlamegraphCommand}" />
                  </StackPanel>
                </Border>
                <Button Content="−" Width="26" Height="26" Padding="0" CornerRadius="5"
                        Command="{Binding ZoomOutCommand}" />
                <Button Content="+" Width="26" Height="26" Padding="0" CornerRadius="5"
                        Command="{Binding ZoomInCommand}" />
                <Button Content="fit" Width="36" Height="26" Padding="0" CornerRadius="5"
                        Command="{Binding ZoomFitCommand}" />
                <Button Content="Export HTML" Height="26" Padding="10,0" CornerRadius="5"
                        Command="{Binding ExportPlanToHtmlCommand}" />
                <Button Content="AI Advisor" Height="26" Padding="10,0" CornerRadius="5"
                        Command="{Binding RunAdvisorCommand}"
                        IsEnabled="{Binding !IsAdvisorRunning}"
                        ToolTip.Tip="Ask AI to analyze SQL and plan (configure key with ⚙)" />
                <Button Content="⚙" Width="26" Height="26" Padding="0" CornerRadius="5"
                        Command="{Binding OpenAdvisorSettingsCommand}"
                        ToolTip.Tip="AI Advisor settings" />
                <StackPanel Orientation="Horizontal" Spacing="4" VerticalAlignment="Center" Margin="8,0,0,0">
                  <Border Width="8" Height="8" CornerRadius="4" Background="#7BD88F" VerticalAlignment="Center" />
                  <TextBlock Text="OK" FontSize="10" Foreground="#91A0AD" VerticalAlignment="Center"/>
                  <Border Width="8" Height="8" CornerRadius="4" Background="#FFD166" VerticalAlignment="Center" Margin="6,0,0,0"/>
                  <TextBlock Text="Warn" FontSize="10" Foreground="#91A0AD" VerticalAlignment="Center"/>
                  <Border Width="8" Height="8" CornerRadius="4" Background="#FF8A7A" VerticalAlignment="Center" Margin="6,0,0,0"/>
                  <TextBlock Text="Crit" FontSize="10" Foreground="#91A0AD" VerticalAlignment="Center"/>
                </StackPanel>
              </StackPanel>
            </Grid>

            <Grid Grid.Row="1"
                  Margin="0,12,0,0"
                  RowDefinitions="Auto,*"
                  IsVisible="{Binding IsPlanTableVisible}">
              <Grid ColumnDefinitions="*,84,108,96,40" Margin="36,0,4,6">
                <TextBlock Text="Operation" FontSize="11" Foreground="#6F7E89" />
                <TextBlock Grid.Column="1" Text="Cost" FontSize="11" Foreground="#6F7E89" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="2" Text="Rows" FontSize="11" Foreground="#6F7E89" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="3" Text="Time" FontSize="11" Foreground="#6F7E89" HorizontalAlignment="Right" />
                <TextBlock Grid.Column="4" Text="⚠" FontSize="11" Foreground="#6F7E89" HorizontalAlignment="Center" />
              </Grid>
              <TreeView Grid.Row="1"
                        ItemsSource="{Binding PlanTreeRoots}"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                <TreeView.Styles>
                  <Style Selector="TreeViewItem">
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                  </Style>
                </TreeView.Styles>
                <TreeView.Styles>
                  <Style Selector="TreeViewItem">
                    <Setter Property="HorizontalAlignment" Value="Stretch" />
                    <Setter Property="Padding" Value="0" />
                    <Setter Property="ItemsSource" Value="{Binding Children}" />
                  </Style>
                </TreeView.Styles>
                <TreeView.ItemTemplate>
                  <DataTemplate>
                    <Button Padding="0"
                            Margin="0,0,0,3"
                            Background="Transparent"
                            BorderThickness="0"
                            HorizontalAlignment="Stretch"
                            HorizontalContentAlignment="Stretch"
                            Command="{Binding DataContext.SelectPlanTreeNodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}">
                      <Border Background="{Binding SelectionBackground}"
                              BorderBrush="{Binding SelectionBorderBrush}"
                              BorderThickness="1"
                              CornerRadius="5"
                              Padding="8,5">
                        <Grid ColumnDefinitions="*,84,108,96,40">
                          <StackPanel Orientation="Horizontal" Spacing="7">
                            <Border Width="8" Height="8" CornerRadius="4"
                                    Background="{Binding AccentColor}" VerticalAlignment="Center" />
                            <TextBlock Text="{Binding Label}"
                                       FontFamily="Menlo, Consolas, monospace"
                                       FontSize="12"
                                       Foreground="#E7ECEF"
                                       TextTrimming="CharacterEllipsis"
                                       VerticalAlignment="Center" />
                          </StackPanel>
                          <TextBlock Grid.Column="1" Text="{Binding CostCell}"
                                     FontFamily="Menlo, Consolas, monospace" FontSize="11"
                                     Foreground="#91A0AD" HorizontalAlignment="Right" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="2" Text="{Binding RowsCell}"
                                     FontFamily="Menlo, Consolas, monospace" FontSize="11"
                                     Foreground="#91A0AD" HorizontalAlignment="Right" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="3" Text="{Binding TimeCell}"
                                     FontFamily="Menlo, Consolas, monospace" FontSize="11"
                                     Foreground="#91A0AD" HorizontalAlignment="Right" VerticalAlignment="Center" />
                          <TextBlock Grid.Column="4" Text="{Binding IssueGlyph}"
                                     FontSize="12" FontWeight="Bold"
                                     Foreground="{Binding IssueColor}"
                                     HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>
                      </Border>
                    </Button>
                  </DataTemplate>
                </TreeView.ItemTemplate>
              </TreeView>
            </Grid>

            <controls:PlanGraphControl
                Grid.Row="1"
                Margin="0,12,0,0"
                IsVisible="{Binding IsPlanGraphVisible}"
                NodesSource="{Binding VisualPlanNodes}"
                EdgesSource="{Binding GraphEdges}"
                CanvasWidth="{Binding GraphWidth}"
                CanvasHeight="{Binding GraphHeight}"
                GraphZoom="{Binding GraphZoom}"
                DataContext="{Binding DataContext, RelativeSource={RelativeSource AncestorType=Window}}"/>

            <ScrollViewer Grid.Row="1"
                          Margin="0,12,0,0"
                          IsVisible="{Binding IsPlanFlamegraphVisible}">
              <ItemsControl ItemsSource="{Binding VisualPlanNodes}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Button Margin="{Binding FlameMargin}"
                            Padding="0"
                            Background="Transparent"
                            BorderBrush="Transparent"
                            HorizontalAlignment="Left"
                            Command="{Binding DataContext.SelectPlanNodeCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                            CommandParameter="{Binding}">
                      <Grid ColumnDefinitions="Auto,*" ColumnSpacing="12">
                        <Border Width="{Binding FlameBarWidth}"
                                Height="34"
                                Background="{Binding AccentColor}"
                                BorderBrush="{Binding SelectionBorderBrush}"
                                BorderThickness="1"
                                CornerRadius="6" />
                        <StackPanel Grid.Column="1"
                                    Orientation="Horizontal"
                                    Spacing="12"
                                    VerticalAlignment="Center">
                          <TextBlock Text="{Binding Label}"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     TextWrapping="NoWrap" />
                          <TextBlock Text="{Binding FlameMetricText}"
                                     FontSize="12"
                                     Foreground="#91A0AD" />
                          <TextBlock Text="{Binding IssueText}"
                                     FontSize="12"
                                     FontWeight="SemiBold"
                                     Foreground="{Binding IssueColor}" />
                        </StackPanel>
                      </Grid>
                    </Button>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>

            <!-- AI Advisor output panel (Row 2 of outer plan Grid) -->
            <Border Grid.Row="2"
                    IsVisible="{Binding IsAdvisorPanelVisible}"
                    Background="#0D1829" BorderBrush="#1E3A5F" BorderThickness="0,1,0,0"
                    MinHeight="120" MaxHeight="300">
              <Grid RowDefinitions="Auto,*">
                <Grid Grid.Row="0" ColumnDefinitions="*,Auto" Margin="0,4,4,0">
                  <TextBlock Text="AI Advisor" FontWeight="SemiBold" Foreground="#80B8FF" Margin="12,8"/>
                  <Button Grid.Column="1" Content="✕" Width="26" Height="26" Padding="0"
                          Command="{Binding CloseAdvisorPanelCommand}"/>
                </Grid>
                <ScrollViewer Grid.Row="1">
                  <TextBlock Text="{Binding AdvisorOutput}" TextWrapping="Wrap"
                             Margin="12,4,12,12"
                             FontFamily="Cascadia Code,Consolas,monospace"
                             Foreground="#C8D8E8" FontSize="12"/>
                </ScrollViewer>
              </Grid>
            </Border>
          </Grid>
        </Border>

        <Border Grid.Column="1" Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Text="Plan Summary" FontSize="14" FontWeight="SemiBold" />
            <Border Padding="10"
                    Background="#0F1419"
                    BorderBrush="#26313A"
                    BorderThickness="1"
                    CornerRadius="6">
              <TextBlock Text="{Binding PlanSummaryText}"
                         FontFamily="Menlo, Consolas, monospace"
                         FontSize="11"
                         Foreground="#91A0AD"
                         TextWrapping="Wrap"
                         LineHeight="18" />
            </Border>
            <Border Height="1" Background="#26313A" />
            <TextBlock Text="Selected Node" FontSize="14" FontWeight="SemiBold" />
            <Border Padding="10"
                    Background="#0F1419"
                    BorderBrush="#26313A"
                    BorderThickness="1"
                    CornerRadius="8">
              <StackPanel Spacing="8">
                <TextBlock Text="{Binding SelectedPlanNodeTitle}"
                           FontSize="13"
                           FontWeight="SemiBold"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding SelectedPlanNodeDetails}"
                           FontFamily="Menlo, Consolas, monospace"
                           FontSize="12"
                           Foreground="#91A0AD"
                           TextWrapping="Wrap" />
                <ItemsControl ItemsSource="{Binding SelectedPlanNodeIssues}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Border Margin="0,0,0,6"
                              Padding="8"
                              Background="#17212A"
                              BorderBrush="#2A3640"
                              BorderThickness="1"
                              CornerRadius="6">
                        <StackPanel Spacing="4">
                          <Grid ColumnDefinitions="*,Auto">
                            <TextBlock Text="{Binding Code}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="#C6D0D8" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding Severity}"
                                       FontSize="11"
                                       Foreground="{Binding SeverityColor}" />
                          </Grid>
                          <TextBlock Text="{Binding Recommendation}"
                                     FontSize="11"
                                     Foreground="#91A0AD"
                                     TextWrapping="Wrap" />
                        </StackPanel>
                      </Border>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
            <Border Height="1" Background="#26313A" />
            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
              <TextBlock Text="Issues" FontSize="14" FontWeight="SemiBold" />
              <Border Padding="6,2"
                      Background="#1F1010"
                      BorderBrush="#3A2020"
                      BorderThickness="1"
                      CornerRadius="4"
                      IsVisible="{Binding HasPlanIssues}">
                <TextBlock Text="{Binding PlanIssuesBadgeText}"
                           FontSize="10"
                           FontWeight="SemiBold"
                           Foreground="{Binding PlanIssuesBadgeColor}" />
              </Border>
            </StackPanel>
            <ScrollViewer MaxHeight="220">
              <ItemsControl ItemsSource="{Binding PlanIssues}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="10"
                            Background="#0F1419"
                            BorderBrush="#26313A"
                            BorderThickness="1"
                            CornerRadius="8">
                      <StackPanel Spacing="6">
                        <Grid ColumnDefinitions="*,Auto">
                          <TextBlock Text="{Binding Title}"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     TextWrapping="Wrap" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Severity}"
                                     Foreground="{Binding SeverityColor}"
                                     FontSize="12"
                                     FontWeight="SemiBold" />
                        </Grid>
                        <TextBlock Text="{Binding Code}"
                                   FontSize="11"
                                   Foreground="#6F7E89" />
                        <TextBlock Text="{Binding Description}"
                                   FontSize="12"
                                   Foreground="#C6D0D8"
                                   TextWrapping="Wrap" />
                        <TextBlock Text="{Binding Recommendation}"
                                   FontSize="12"
                                   Foreground="#91A0AD"
                                   TextWrapping="Wrap" />
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </StackPanel>
        </Border>
      </Grid>

      <Grid Grid.Row="1"
            Grid.RowSpan="2"
            Classes="content-view"
            ColumnDefinitions="360,*"
            ColumnSpacing="16"
            IsVisible="{Binding IsConnectionsVisible}">
        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Text="{Binding ConnectionFormTitle}" FontSize="14" FontWeight="SemiBold" />

            <StackPanel Spacing="6">
              <TextBlock Text="Name" FontSize="12" Foreground="#91A0AD" />
              <TextBox Text="{Binding NewConnectionName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Watermark="Production DB" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="Type" FontSize="12" Foreground="#91A0AD" />
              <ComboBox ItemsSource="{Binding DatabaseTypeOptions}"
                        SelectedItem="{Binding NewConnectionDatabaseType}" />
            </StackPanel>

            <Grid ColumnDefinitions="*,100" ColumnSpacing="10"
                  IsVisible="{Binding !IsLocalDatabaseConnection}">
              <StackPanel Spacing="6">
                <TextBlock Text="Host" FontSize="12" Foreground="#91A0AD" />
                <TextBox Text="{Binding NewConnectionHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Watermark="localhost" />
              </StackPanel>

              <StackPanel Grid.Column="1" Spacing="6">
                <TextBlock Text="Port" FontSize="12" Foreground="#91A0AD" />
                <TextBox Text="{Binding NewConnectionPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Watermark="5432" />
              </StackPanel>
            </Grid>

            <StackPanel Spacing="6">
              <TextBlock Text="{Binding NewConnectionDatabaseLabel}"
                         FontSize="12" Foreground="#91A0AD" />
              <TextBox Text="{Binding NewConnectionDatabase, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Watermark="{Binding NewConnectionDatabaseWatermark}" />
            </StackPanel>

            <StackPanel Spacing="6" IsVisible="{Binding !IsLocalDatabaseConnection}">
              <TextBlock Text="Username" FontSize="12" Foreground="#91A0AD" />
              <TextBox Text="{Binding NewConnectionUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Watermark="postgres" />
            </StackPanel>

            <StackPanel Spacing="6" IsVisible="{Binding !IsLocalDatabaseConnection}">
              <TextBlock Text="Password" FontSize="12" Foreground="#91A0AD" />
              <TextBox Text="{Binding NewConnectionPassword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PasswordChar="*"
                       Watermark="Used for test only" />
            </StackPanel>

            <CheckBox Content="Use SSL" IsChecked="{Binding NewConnectionUseSsl}"
                      IsVisible="{Binding !IsLocalDatabaseConnection}" />

            <Grid ColumnDefinitions="*,*,Auto" ColumnSpacing="10">
              <Button Content="Test Connection"
                      Height="36"
                      HorizontalAlignment="Stretch"
                      Command="{Binding TestConnectionCommand}" />
              <Button Grid.Column="1"
                      Content="{Binding SaveConnectionButtonText}"
                      Height="36"
                      HorizontalAlignment="Stretch"
                      Command="{Binding SaveConnectionCommand}" />
              <Button Grid.Column="2"
                      Content="Cancel"
                      Height="36"
                      Padding="12,0"
                      Background="#17212A"
                      BorderBrush="#2A3640"
                      IsVisible="{Binding IsEditingConnection}"
                      Command="{Binding CancelConnectionEditCommand}" />
            </Grid>

            <TextBlock Text="{Binding ConnectionStatusMessage}"
                       FontSize="12"
                       Foreground="#91A0AD"
                       TextWrapping="Wrap" />
            <TextBlock Text="Passwords are stored in the OS keychain (Windows DPAPI / macOS Keychain / Linux secret-tool)."
                       FontSize="11"
                       Foreground="#6F7E89"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Classes="panel">
          <Grid RowDefinitions="Auto,*">
            <TextBlock Text="Saved Connections" FontSize="14" FontWeight="SemiBold" />

            <ScrollViewer Grid.Row="1" Margin="0,12,0,0">
              <ItemsControl ItemsSource="{Binding Connections}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="14"
                            Background="#0F1419"
                            BorderBrush="#26313A"
                            BorderThickness="1"
                            CornerRadius="8">
                      <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="Auto,*">
                          <Border Padding="6,3"
                                  Background="#17212A"
                                  BorderBrush="#2A3640"
                                  BorderThickness="1"
                                  CornerRadius="5">
                            <TextBlock Text="{Binding DatabaseTypeShort}"
                                       FontSize="10"
                                       FontWeight="Bold"
                                       Foreground="{Binding DatabaseTypeColor}" />
                          </Border>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding Name}"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     Margin="10,0,0,0"
                                     VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock Text="{Binding Endpoint}"
                                   FontSize="12"
                                   Foreground="#91A0AD" />

                        <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="8"
                              IsVisible="{Binding IsPendingDelete, Converter={x:Static BoolConverters.Not}}">
                          <TextBlock Text="{Binding Database}"
                                     FontSize="12"
                                     Foreground="#C6D0D8"
                                     VerticalAlignment="Center" />
                          <Button Grid.Column="1"
                                  Content="Edit"
                                  Height="28"
                                  Padding="10,0"
                                  CornerRadius="5"
                                  Background="#17212A"
                                  BorderBrush="#2A3640"
                                  Command="{Binding DataContext.EditConnectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                          <Button Grid.Column="2"
                                  Content="Connect"
                                  Height="28"
                                  Padding="10,0"
                                  CornerRadius="5"
                                  Command="{Binding DataContext.SelectConnectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                          <Button Grid.Column="3"
                                  Content="Delete"
                                  Height="28"
                                  Padding="10,0"
                                  CornerRadius="5"
                                  Background="Transparent"
                                  BorderBrush="#3A2020"
                                  Foreground="#FF8A7A"
                                  Command="{Binding DataContext.RequestDeleteConnectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"
                              IsVisible="{Binding IsPendingDelete}">
                          <TextBlock Text="Delete this connection?"
                                     FontSize="12"
                                     Foreground="#91A0AD"
                                     VerticalAlignment="Center" />
                          <Button Grid.Column="1"
                                  Content="Confirm delete"
                                  Height="28"
                                  Padding="10,0"
                                  CornerRadius="5"
                                  Background="Transparent"
                                  BorderBrush="#3A2020"
                                  Foreground="#FF8A7A"
                                  Command="{Binding DataContext.DeleteConnectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                          <Button Grid.Column="2"
                                  Content="Cancel"
                                  Height="28"
                                  Padding="10,0"
                                  CornerRadius="5"
                                  Background="#17212A"
                                  BorderBrush="#2A3640"
                                  Command="{Binding DataContext.CancelDeleteConnectionCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                        </Grid>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Row="1"
              Grid.RowSpan="2"
              Classes="panel content-view"
              IsVisible="{Binding IsHistoryVisible}">
        <Grid RowDefinitions="Auto,Auto,*">
          <Grid ColumnDefinitions="*,Auto">
            <TextBlock Text="Recent Queries" FontSize="14" FontWeight="SemiBold" />
            <Button Grid.Column="1"
                    Content="Refresh"
                    Height="32"
                    Padding="14,0"
                    Command="{Binding LoadHistoryCommand}" />
          </Grid>

          <Border Grid.Row="1" Margin="0,10,0,0" Padding="10,8"
                  Background="#0F1419" BorderBrush="#26313A" BorderThickness="1" CornerRadius="6">
            <Grid ColumnDefinitions="*,Auto,Auto,Auto,Auto" ColumnSpacing="8">
              <TextBox Text="{Binding HistoryFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Watermark="Search SQL or connection…" FontSize="12" MinHeight="0" />
              <CheckBox Grid.Column="1" Content="Slow only" IsChecked="{Binding HistoryShowSlowOnly}"
                        FontSize="12" VerticalAlignment="Center" />
              <TextBox Grid.Column="2" Text="{Binding HistorySlowThresholdMs, Mode=TwoWay}"
                       Width="64" FontSize="12" MinHeight="0" VerticalAlignment="Center" />
              <TextBlock Grid.Column="3" Text="ms" FontSize="12" Foreground="#91A0AD" VerticalAlignment="Center" />
              <Button Grid.Column="4" Content="Apply" Height="28" Padding="10,0" CornerRadius="5"
                      Command="{Binding ApplyHistoryFiltersCommand}" />
            </Grid>
          </Border>

          <ScrollViewer Grid.Row="2" Margin="0,12,0,0">
            <ItemsControl ItemsSource="{Binding HistoryItems}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Margin="0,0,0,8"
                          Padding="12,10"
                          Background="#0F1419"
                          BorderBrush="#26313A"
                          BorderThickness="1"
                          CornerRadius="7">
                    <StackPanel Spacing="6">
                      <Grid ColumnDefinitions="Auto,*,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto" ColumnSpacing="8"
                            IsVisible="{Binding IsPendingDelete, Converter={x:Static BoolConverters.Not}}">
                        <Border Padding="5,2"
                                Background="{Binding StatusBadgeBackground}"
                                CornerRadius="3"
                                VerticalAlignment="Center">
                          <TextBlock Text="{Binding StatusBadgeText}"
                                     FontSize="9"
                                     FontWeight="Bold"
                                     Foreground="{Binding StatusBadgeForeground}" />
                        </Border>
                        <TextBlock Grid.Column="1"
                                   Text="{Binding ConnectionName}"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#C6D0D8"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="2"
                                   Text="{Binding ExecutedAt}"
                                   FontSize="10"
                                   Foreground="#4A5A66"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="3"
                                   Text="{Binding Duration}"
                                   FontSize="10"
                                   Foreground="#91A0AD"
                                   VerticalAlignment="Center" />
                        <TextBlock Grid.Column="4"
                                   Text="{Binding RowCount}"
                                   FontSize="10"
                                   Foreground="#91A0AD"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="5"
                                Content="Open"
                                Height="26"
                                Padding="8,0"
                                CornerRadius="4"
                                Command="{Binding DataContext.OpenHistoryItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                        <Button Grid.Column="6"
                                Content="Plan"
                                Height="26"
                                Padding="8,0"
                                CornerRadius="4"
                                Background="#17212A"
                                BorderBrush="#2A3640"
                                IsVisible="{Binding HasSavedPlan}"
                                Command="{Binding DataContext.OpenHistoryPlanCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                        <Button Grid.Column="7"
                                Content="Copy SQL"
                                Height="26"
                                Padding="8,0"
                                CornerRadius="4"
                                Background="#151C22"
                                BorderBrush="#2A3640"
                                Command="{Binding DataContext.CopyHistoryItemSqlCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                        <Button Grid.Column="8"
                                Content="→ Snippet"
                                Height="26"
                                Padding="8,0"
                                CornerRadius="4"
                                Background="#151C22"
                                BorderBrush="#2A3640"
                                Command="{Binding DataContext.AddHistoryItemToSnippetsCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                        <Button Grid.Column="9"
                                Content="Delete"
                                Height="26"
                                Padding="8,0"
                                CornerRadius="4"
                                Background="Transparent"
                                BorderBrush="#3A2020"
                                Foreground="#FF8A7A"
                                Command="{Binding DataContext.RequestDeleteHistoryItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                      </Grid>
                      <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"
                            IsVisible="{Binding IsPendingDelete}">
                        <TextBlock Text="Delete this entry?"
                                   FontSize="12"
                                   Foreground="#91A0AD"
                                   VerticalAlignment="Center" />
                        <Button Grid.Column="1"
                                Content="Confirm delete"
                                Height="26"
                                Padding="8,0"
                                CornerRadius="4"
                                Background="Transparent"
                                BorderBrush="#3A2020"
                                Foreground="#FF8A7A"
                                Command="{Binding DataContext.DeleteHistoryItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                        <Button Grid.Column="2"
                                Content="Cancel"
                                Height="26"
                                Padding="8,0"
                                CornerRadius="4"
                                Background="#17212A"
                                BorderBrush="#2A3640"
                                Command="{Binding DataContext.CancelDeleteHistoryItemCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                CommandParameter="{Binding}" />
                      </Grid>

                      <Border Padding="8,6"
                              Background="#0A0F13"
                              BorderBrush="#1E2830"
                              BorderThickness="1"
                              CornerRadius="5">
                        <TextBlock Text="{Binding SqlPreview}"
                                   FontFamily="Menlo, Consolas, monospace"
                                   FontSize="11"
                                   Foreground="#CFE3F2"
                                   TextWrapping="NoWrap" />
                      </Border>

                      <TextBlock Text="{Binding ErrorMessage}"
                                 FontSize="11"
                                 Foreground="#FF8A7A"
                                 TextWrapping="Wrap"
                                 IsVisible="{Binding ErrorMessage, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>

      <Grid Grid.Row="1"
            Grid.RowSpan="2"
            Classes="content-view"
            ColumnDefinitions="340,*"
            ColumnSpacing="16"
            IsVisible="{Binding IsSnippetsVisible}">
        <Border Classes="panel">
          <StackPanel Spacing="12">
            <TextBlock Text="New Snippet" FontSize="14" FontWeight="SemiBold" />

            <StackPanel Spacing="6">
              <TextBlock Text="Name" FontSize="12" Foreground="#91A0AD" />
              <TextBox Text="{Binding NewSnippetName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Watermark="e.g. Count active users" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="Description" FontSize="12" Foreground="#91A0AD" />
              <TextBox Text="{Binding NewSnippetDescription, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Watermark="Optional note" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="Tags" FontSize="12" Foreground="#91A0AD" />
              <TextBox Text="{Binding NewSnippetTags, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Watermark="reporting, orders, maintenance" />
            </StackPanel>

            <StackPanel Spacing="6">
              <TextBlock Text="SQL" FontSize="12" Foreground="#91A0AD" />
              <TextBox Text="{Binding NewSnippetSqlText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       Watermark="SELECT ..."
                       AcceptsReturn="True"
                       MinHeight="120"
                       MaxHeight="200"
                       FontFamily="Menlo, Consolas, monospace"
                       FontSize="12" />
            </StackPanel>

            <Button Content="Save Snippet"
                    Height="36"
                    HorizontalAlignment="Stretch"
                    Command="{Binding SaveSnippetCommand}" />

            <TextBlock Text="{Binding SnippetStatusMessage}"
                       FontSize="12"
                       Foreground="#91A0AD"
                       TextWrapping="Wrap" />
          </StackPanel>
        </Border>

        <Border Grid.Column="1" Classes="panel">
          <Grid RowDefinitions="Auto,Auto,*">
            <Grid ColumnDefinitions="*,Auto">
              <TextBlock Text="Saved Snippets" FontSize="14" FontWeight="SemiBold" />
              <Button Grid.Column="1"
                      Content="Refresh"
                      Height="32"
                      Padding="14,0"
                    Command="{Binding LoadSnippetsCommand}" />
            </Grid>

            <TextBox Grid.Row="1"
                     Margin="0,12,0,0"
                     Text="{Binding SnippetFilterText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Watermark="Search name, SQL, description, or tag…"
                     FontSize="12" />

            <ScrollViewer Grid.Row="2" Margin="0,12,0,0">
              <ItemsControl ItemsSource="{Binding Snippets}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border Margin="0,0,0,10"
                            Padding="14"
                            Background="#0F1419"
                            BorderBrush="#26313A"
                            BorderThickness="1"
                            CornerRadius="8">
                      <StackPanel Spacing="8">
                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                          <TextBlock Text="{Binding Name}"
                                     FontSize="14"
                                     FontWeight="SemiBold"
                                     VerticalAlignment="Center" />
                          <TextBlock Grid.Column="1"
                                     Text="{Binding CreatedAt}"
                                     FontSize="10"
                                     Foreground="#4A5A66"
                                     VerticalAlignment="Center" />
                        </Grid>

                        <TextBlock Text="{Binding Description}"
                                   FontSize="12"
                                   Foreground="#91A0AD"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding Description, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <TextBlock Text="{Binding TagsDisplay}"
                                   FontSize="11"
                                   Foreground="#80B8FF"
                                   TextWrapping="Wrap"
                                   IsVisible="{Binding TagsDisplay, Converter={x:Static StringConverters.IsNotNullOrEmpty}}" />

                        <Border Padding="8,6"
                                Background="#0A0F13"
                                BorderBrush="#1E2830"
                                BorderThickness="1"
                                CornerRadius="5">
                          <TextBlock Text="{Binding SqlPreview}"
                                     FontFamily="Menlo, Consolas, monospace"
                                     FontSize="11"
                                     Foreground="#CFE3F2"
                                     TextWrapping="NoWrap" />
                        </Border>

                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"
                              IsVisible="{Binding IsPendingDelete, Converter={x:Static BoolConverters.Not}}">
                          <Border />
                          <Button Grid.Column="1"
                                  Content="Open"
                                  Height="28"
                                  Padding="10,0"
                                  CornerRadius="5"
                                  Command="{Binding DataContext.OpenSnippetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                          <Button Grid.Column="2"
                                  Content="Delete"
                                  Height="28"
                                  Padding="10,0"
                                  CornerRadius="5"
                                  Background="Transparent"
                                  BorderBrush="#3A2020"
                                  Foreground="#FF8A7A"
                                  Command="{Binding DataContext.RequestDeleteSnippetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                        </Grid>
                        <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="8"
                              IsVisible="{Binding IsPendingDelete}">
                          <TextBlock Text="Delete this snippet?"
                                     FontSize="12"
                                     Foreground="#91A0AD"
                                     VerticalAlignment="Center" />
                          <Button Grid.Column="1"
                                  Content="Confirm delete"
                                  Height="28"
                                  Padding="10,0"
                                  CornerRadius="5"
                                  Background="Transparent"
                                  BorderBrush="#3A2020"
                                  Foreground="#FF8A7A"
                                  Command="{Binding DataContext.DeleteSnippetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                          <Button Grid.Column="2"
                                  Content="Cancel"
                                  Height="28"
                                  Padding="10,0"
                                  CornerRadius="5"
                                  Background="#17212A"
                                  BorderBrush="#2A3640"
                                  Command="{Binding DataContext.CancelDeleteSnippetCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                  CommandParameter="{Binding}" />
                        </Grid>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </ScrollViewer>
          </Grid>
        </Border>
      </Grid>

      <Border Grid.Row="1"
              Grid.RowSpan="2"
              Classes="panel content-view"
              IsVisible="{Binding IsCompareVisible}">
        <Grid RowDefinitions="Auto,Auto,*,Auto">

          <!-- header row -->
          <Grid ColumnDefinitions="*,Auto,Auto,Auto" ColumnSpacing="10" Margin="0,0,0,16">
            <TextBlock Text="Compare Queries"
                       FontSize="14"
                       FontWeight="SemiBold"
                       VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Text="{Binding CompareStatusMessage}"
                       FontSize="12"
                       Foreground="#91A0AD"
                       VerticalAlignment="Center" />
            <Button Grid.Column="2"
                    Content="Run Compare"
                    Height="28"
                    Padding="10,0"
                    CornerRadius="5"
                    Background="#151C22"
                    BorderBrush="#2A3640"
                    IsEnabled="{Binding !IsCompareRunning}"
                    Command="{Binding RunCompareCommand}" />
                <Button Grid.Column="3"
                        Content="Export Report"
                        Height="28"
                        Padding="10,0"
                        CornerRadius="5"
                        Background="#151C22"
                        BorderBrush="#2A3640"
                        IsEnabled="{Binding CompareHasResults}"
                        Command="{Binding ExportCompareToHtmlCommand}" />
          </Grid>

          <!-- two SQL inputs -->
          <Grid Grid.Row="1" ColumnDefinitions="*,12,*" Margin="0,0,0,16">
            <Border Background="#0F1419"
                    BorderBrush="#26313A"
                    BorderThickness="1"
                    CornerRadius="6">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Query A"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#91A0AD"
                           Margin="10,8,10,6" />
                <TextBox Grid.Row="1"
                         Text="{Binding CompareQueryAText}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas,Menlo,monospace"
                         FontSize="12"
                         Foreground="#E7ECEF"
                         Background="Transparent"
                         BorderThickness="0"
                         MinHeight="120"
                         Padding="10,0,10,10" />
              </Grid>
            </Border>

            <Border Grid.Column="2"
                    Background="#0F1419"
                    BorderBrush="#26313A"
                    BorderThickness="1"
                    CornerRadius="6">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Query B"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="#91A0AD"
                           Margin="10,8,10,6" />
                <TextBox Grid.Row="1"
                         Text="{Binding CompareQueryBText}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         FontFamily="Consolas,Menlo,monospace"
                         FontSize="12"
                         Foreground="#E7ECEF"
                         Background="Transparent"
                         BorderThickness="0"
                         MinHeight="120"
                         Padding="10,0,10,10" />
              </Grid>
            </Border>
          </Grid>

          <!-- results -->
          <Grid Grid.Row="2" ColumnDefinitions="*,12,*" IsVisible="{Binding CompareHasResults}">

            <!-- Result A card -->
            <Border Background="#0F1419"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    BorderBrush="{Binding CompareResultA.WinnerBorderBrush}">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding CompareResultA.Label}"
                             FontSize="13"
                             FontWeight="SemiBold"
                             Foreground="#C6D0D8" />
                  <Border Grid.Column="1"
                          Padding="6,2"
                          CornerRadius="4"
                          Background="#0D2211"
                          IsVisible="{Binding CompareResultA.IsWinner}">
                    <TextBlock Text="Winner"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="#7BD88F" />
                  </Border>
                </Grid>
                <TextBlock Text="{Binding CompareResultA.RootLabel}"
                           FontSize="11"
                           Foreground="#91A0AD"
                           TextTrimming="CharacterEllipsis" />
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                  <StackPanel>
                    <TextBlock Text="Time" FontSize="10" Foreground="#6F7E89" />
                    <TextBlock Text="{Binding CompareResultA.TimeText}" FontSize="12" Foreground="#E7ECEF" />
                  </StackPanel>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="Cost" FontSize="10" Foreground="#6F7E89" />
                    <TextBlock Text="{Binding CompareResultA.CostText}" FontSize="12" Foreground="#E7ECEF" />
                  </StackPanel>
                  <StackPanel Grid.Row="1">
                    <TextBlock Text="Est. rows" FontSize="10" Foreground="#6F7E89" />
                    <TextBlock Text="{Binding CompareResultA.EstRowsText}" FontSize="12" Foreground="#E7ECEF" />
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBlock Text="Act. rows" FontSize="10" Foreground="#6F7E89" />
                    <TextBlock Text="{Binding CompareResultA.ActRowsText}" FontSize="12" Foreground="#E7ECEF" />
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding CompareResultA.NodeCountText}"
                             FontSize="11"
                             Foreground="#6F7E89"
                             VerticalAlignment="Center" />
                  <Border Grid.Column="1"
                          Padding="6,2"
                          CornerRadius="4"
                          Background="#0F1419">
                    <TextBlock Text="{Binding CompareResultA.IssueText}"
                               FontSize="10"
                               Foreground="{Binding CompareResultA.IssueColor}" />
                  </Border>
                </Grid>
              </StackPanel>
            </Border>

            <!-- Result B card -->
            <Border Grid.Column="2"
                    Background="#0F1419"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="14"
                    BorderBrush="{Binding CompareResultB.WinnerBorderBrush}">
              <StackPanel Spacing="10">
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding CompareResultB.Label}"
                             FontSize="13"
                             FontWeight="SemiBold"
                             Foreground="#C6D0D8" />
                  <Border Grid.Column="1"
                          Padding="6,2"
                          CornerRadius="4"
                          Background="#0D2211"
                          IsVisible="{Binding CompareResultB.IsWinner}">
                    <TextBlock Text="Winner"
                               FontSize="10"
                               FontWeight="Bold"
                               Foreground="#7BD88F" />
                  </Border>
                </Grid>
                <TextBlock Text="{Binding CompareResultB.RootLabel}"
                           FontSize="11"
                           Foreground="#91A0AD"
                           TextTrimming="CharacterEllipsis" />
                <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="6">
                  <StackPanel>
                    <TextBlock Text="Time" FontSize="10" Foreground="#6F7E89" />
                    <TextBlock Text="{Binding CompareResultB.TimeText}" FontSize="12" Foreground="#E7ECEF" />
                  </StackPanel>
                  <StackPanel Grid.Column="1">
                    <TextBlock Text="Cost" FontSize="10" Foreground="#6F7E89" />
                    <TextBlock Text="{Binding CompareResultB.CostText}" FontSize="12" Foreground="#E7ECEF" />
                  </StackPanel>
                  <StackPanel Grid.Row="1">
                    <TextBlock Text="Est. rows" FontSize="10" Foreground="#6F7E89" />
                    <TextBlock Text="{Binding CompareResultB.EstRowsText}" FontSize="12" Foreground="#E7ECEF" />
                  </StackPanel>
                  <StackPanel Grid.Row="1" Grid.Column="1">
                    <TextBlock Text="Act. rows" FontSize="10" Foreground="#6F7E89" />
                    <TextBlock Text="{Binding CompareResultB.ActRowsText}" FontSize="12" Foreground="#E7ECEF" />
                  </StackPanel>
                </Grid>
                <Grid ColumnDefinitions="*,Auto">
                  <TextBlock Text="{Binding CompareResultB.NodeCountText}"
                             FontSize="11"
                             Foreground="#6F7E89"
                             VerticalAlignment="Center" />
                  <Border Grid.Column="1"
                          Padding="6,2"
                          CornerRadius="4"
                          Background="#0F1419">
                    <TextBlock Text="{Binding CompareResultB.IssueText}"
                               FontSize="10"
                               Foreground="{Binding CompareResultB.IssueColor}" />
                  </Border>
                </Grid>
              </StackPanel>
            </Border>

          </Grid>

          <!-- Plan node trees -->
          <Grid Grid.Row="3" ColumnDefinitions="*,12,*" Margin="0,10,0,0"
                IsVisible="{Binding CompareHasResults}">
            <Border Background="#0F1419" BorderBrush="#26313A" BorderThickness="1" CornerRadius="8" Padding="12">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Query A — Plan" FontSize="11" FontWeight="SemiBold" Foreground="#91A0AD" Margin="0,0,0,8"/>
                <ScrollViewer Grid.Row="1" MaxHeight="240">
                  <ItemsControl ItemsSource="{Binding ComparePlanNodesA}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,2" Padding="6,4" Background="{Binding SelectionBackground}"
                                CornerRadius="3">
                          <Grid ColumnDefinitions="*,72,80,30">
                            <StackPanel Orientation="Horizontal" Spacing="5" Margin="{Binding TreeIndentMargin}">
                              <Border Width="6" Height="6" CornerRadius="3" Background="{Binding AccentColor}" VerticalAlignment="Center"/>
                              <TextBlock Text="{Binding Label}" FontFamily="Menlo,Consolas,monospace" FontSize="11"
                                         TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding CostCell}" FontSize="10" Foreground="#91A0AD" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding TimeCell}" FontSize="10" Foreground="#91A0AD" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding IssueGlyph}" FontSize="11" FontWeight="Bold" Foreground="{Binding IssueColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Grid>
            </Border>
            <Border Grid.Column="2" Background="#0F1419" BorderBrush="#26313A" BorderThickness="1" CornerRadius="8" Padding="12">
              <Grid RowDefinitions="Auto,*">
                <TextBlock Text="Query B — Plan" FontSize="11" FontWeight="SemiBold" Foreground="#91A0AD" Margin="0,0,0,8"/>
                <ScrollViewer Grid.Row="1" MaxHeight="240">
                  <ItemsControl ItemsSource="{Binding ComparePlanNodesB}">
                    <ItemsControl.ItemTemplate>
                      <DataTemplate>
                        <Border Margin="0,0,0,2" Padding="6,4" Background="{Binding SelectionBackground}"
                                CornerRadius="3">
                          <Grid ColumnDefinitions="*,72,80,30">
                            <StackPanel Orientation="Horizontal" Spacing="5" Margin="{Binding TreeIndentMargin}">
                              <Border Width="6" Height="6" CornerRadius="3" Background="{Binding AccentColor}" VerticalAlignment="Center"/>
                              <TextBlock Text="{Binding Label}" FontFamily="Menlo,Consolas,monospace" FontSize="11"
                                         TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" Text="{Binding CostCell}" FontSize="10" Foreground="#91A0AD" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="2" Text="{Binding TimeCell}" FontSize="10" Foreground="#91A0AD" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="3" Text="{Binding IssueGlyph}" FontSize="11" FontWeight="Bold" Foreground="{Binding IssueColor}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                          </Grid>
                        </Border>
                      </DataTemplate>
                    </ItemsControl.ItemTemplate>
                  </ItemsControl>
                </ScrollViewer>
              </Grid>
            </Border>
          </Grid>

        </Grid>
      </Border>

      <Border Grid.Row="2" Classes="panel" IsVisible="{Binding IsWorkspaceVisible}">
        <Grid RowDefinitions="Auto,*">
          <Grid ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
            <TextBlock Text="Results" FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center" />
            <TextBlock Grid.Column="1"
                       Text="{Binding QueryStatusMessage}"
                       FontSize="12"
                       Foreground="#91A0AD"
                       VerticalAlignment="Center" />
            <Button Grid.Column="2"
                    Content="Export CSV"
                    Height="28"
                    Padding="10,0"
                    CornerRadius="5"
                    Background="#151C22"
                    BorderBrush="#2A3640"
                    Command="{Binding ExportResultsToCsvCommand}" />
          </Grid>
          <Grid Grid.Row="1" Margin="0,12,0,0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Disabled">
              <Grid Width="{Binding ResultTotalWidth}" RowDefinitions="Auto,*">
                <ItemsControl Grid.Row="0" ItemsSource="{Binding ResultColumnsView}">
                  <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                      <StackPanel Orientation="Horizontal" />
                    </ItemsPanelTemplate>
                  </ItemsControl.ItemsPanel>
                  <ItemsControl.ItemTemplate>
                    <DataTemplate>
                      <Button Width="{Binding Width}"
                              Height="28"
                              Padding="8,0"
                              HorizontalContentAlignment="Left"
                              VerticalContentAlignment="Center"
                              Background="#0F1419"
                              BorderBrush="#26313A"
                              BorderThickness="0,0,1,1"
                              CornerRadius="0"
                              Command="{Binding DataContext.SortResultsByColumnCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                              CommandParameter="{Binding Name}">
                        <TextBlock Text="{Binding Header}"
                                   FontFamily="Menlo, Consolas, monospace"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="#91A0AD"
                                   TextTrimming="CharacterEllipsis" />
                      </Button>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>

                <ScrollViewer Grid.Row="1"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                  <ListBox x:Name="ResultsListBox"
                           ItemsSource="{Binding ResultRows}"
                           Background="Transparent"
                           BorderThickness="0"
                           Padding="0">
                    <ListBox.Styles>
                      <Style Selector="ListBoxItem">
                        <Setter Property="Padding" Value="0" />
                        <Setter Property="MinHeight" Value="0" />
                      </Style>
                      <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                        <Setter Property="Background" Value="#17212A" />
                      </Style>
                    </ListBox.Styles>
                    <ListBox.KeyBindings>
                      <KeyBinding Gesture="Ctrl+C"
                                  Command="{Binding CopySelectedResultRowCommand}"
                                  CommandParameter="{Binding #ResultsListBox.SelectedItem}" />
                    </ListBox.KeyBindings>
                    <ListBox.ItemTemplate>
                      <DataTemplate>
                        <Border BorderBrush="#202B33" BorderThickness="0,0,0,1">
                          <ItemsControl ItemsSource="{Binding Cells}">
                            <ItemsControl.ItemsPanel>
                              <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal" />
                              </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                              <DataTemplate>
                                <TextBlock Text="{Binding Text}"
                                           Width="{Binding Width}"
                                           FontFamily="Menlo, Consolas, monospace"
                                           FontSize="12"
                                           FontStyle="{Binding FontStyle}"
                                           Foreground="{Binding Foreground}"
                                           Padding="8,4"
                                           TextTrimming="CharacterEllipsis" />
                              </DataTemplate>
                            </ItemsControl.ItemTemplate>
                          </ItemsControl>
                        </Border>
                      </DataTemplate>
                    </ListBox.ItemTemplate>
                  </ListBox>
                </ScrollViewer>
              </Grid>
            </ScrollViewer>
          </Grid>
        </Grid>
      </Border>
    </Grid>
    <!-- Snippets quick-search popup -->
    <Panel Grid.Row="0" Grid.RowSpan="2" Grid.Column="0" Grid.ColumnSpan="2"
           IsVisible="{Binding IsSnippetsPopupVisible}"
           ZIndex="100">
      <Rectangle Fill="#000000" Opacity="0.55" />
      <Border MaxWidth="560" MaxHeight="460"
              HorizontalAlignment="Center" VerticalAlignment="Center"
              Background="#141A20" BorderBrush="#2A3640" BorderThickness="1" CornerRadius="10"
              Padding="16">
        <Grid RowDefinitions="Auto,*">
          <Grid ColumnDefinitions="*,Auto" Margin="0,0,0,10">
            <TextBox Text="{Binding SnippetsPopupSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                     Watermark="Search snippets…" FontSize="14" />
            <Button Grid.Column="1" Content="✕" Width="36" Height="36" Margin="8,0,0,0"
                    Command="{Binding CloseSnippetsPopupCommand}" />
          </Grid>
          <ScrollViewer Grid.Row="1">
            <ItemsControl ItemsSource="{Binding PopupSnippets}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Button HorizontalAlignment="Stretch" HorizontalContentAlignment="Stretch"
                          Padding="0" Background="Transparent" BorderThickness="0"
                          Command="{Binding DataContext.OpenSnippetFromPopupCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                          CommandParameter="{Binding}">
                    <Border Margin="0,0,0,6" Padding="12,8"
                            Background="#0F1419" BorderBrush="#26313A" BorderThickness="1" CornerRadius="6">
                      <StackPanel Spacing="3">
                        <TextBlock Text="{Binding Name}" FontSize="13" FontWeight="SemiBold" />
                        <TextBlock Text="{Binding SqlPreview}"
                                   FontFamily="Menlo, Consolas, monospace" FontSize="11"
                                   Foreground="#91A0AD" TextTrimming="CharacterEllipsis" />
                      </StackPanel>
                    </Border>
                  </Button>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </ScrollViewer>
        </Grid>
      </Border>
      <!-- AI Advisor Settings overlay -->
      <Grid IsVisible="{Binding IsAdvisorSettingsVisible}" ZIndex="200">
        <Rectangle Fill="#CC000000"/>
        <Border Background="#1A2332" BorderBrush="#2A3A4A" BorderThickness="1"
                CornerRadius="12" Padding="24" Width="480"
                HorizontalAlignment="Center" VerticalAlignment="Center">
          <StackPanel Spacing="8">
            <TextBlock Text="AI Advisor Settings" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
            <TextBlock Text="API Key" FontSize="12" Foreground="#91A0AD"/>
            <TextBox Text="{Binding AdvisorApiKey}" PasswordChar="•"
                     Watermark="sk-... or your API key"/>
            <TextBlock Text="Base URL (leave blank for OpenAI default)" FontSize="12"
                       Foreground="#91A0AD" Margin="0,8,0,0"/>
            <TextBox Text="{Binding AdvisorEndpoint}"
                     Watermark="https://api.openai.com/v1"/>
            <TextBlock Text="Model" FontSize="12" Foreground="#91A0AD" Margin="0,8,0,0"/>
            <TextBox Text="{Binding AdvisorModel}" Watermark="gpt-4o-mini"/>
            <StackPanel Orientation="Horizontal" Spacing="8"
                        HorizontalAlignment="Right" Margin="0,16,0,0">
              <Button Content="Cancel" Command="{Binding CloseAdvisorSettingsCommand}"
                      Padding="16,8"/>
              <Button Content="Save" Command="{Binding SaveAdvisorSettingsCommand}"
                      Padding="16,8"/>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>
    </Panel>
  </Grid>
</Window>
